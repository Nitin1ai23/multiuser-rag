# --- API credentials -------------------------------------------------
# NVIDIA NIM is used ONLY for embeddings (Groq has no embeddings API).
# Get a key at https://build.nvidia.com
NVIDIA_API_KEY=

# Groq is used for chat/answer generation. Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# --- NVIDIA NIM embeddings (OpenAI-compatible endpoint) ---------------
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
# Output dimension of the embedding model above.
EMBEDDING_DIM=2048

# --- NVIDIA NIM reranking (improves retrieval precision) -------------
# After dense search, candidates are re-scored by a cross-encoder and the best
# TOP_K are kept; if the endpoint is unreachable it falls back to vector order.
# Off by default: NVIDIA's hosted rerank endpoint is mid-migration (the old URL
# was retired 2026-05-18). To use it, set NIM_RERANK_URL to a working endpoint
# (find the current one on build.nvidia.com, or run a self-hosted NIM at
# http://localhost:8000/v1/ranking) and set RERANK_ENABLED=true.
RERANK_ENABLED=false
NIM_RERANK_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2
NIM_RERANK_URL=
RERANK_CANDIDATE_MULTIPLIER=4

# --- Groq chat -------------------------------------------------------
GROQ_MODEL=llama-3.3-70b-versatile

# --- Vision (image captioning at ingest) -----------------------------
# OCR only recovers characters, so a photo or chart with no text in it would
# index as nothing and the model could only answer "I don't know". With this on,
# uploaded images are also described by a vision model and that description is
# indexed alongside any OCR'd text. Set VISION_ENABLED=false to skip the extra
# call (images then fall back to OCR only).
# GROQ_VISION_MODEL must be vision-capable — GROQ_MODEL above is text-only.
VISION_ENABLED=true
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VISION_MAX_TOKENS=400
# Long edge (px) images are downscaled to before upload: keeps requests under
# Groq's size limit and cuts latency.
VISION_MAX_PIXELS=1024

# --- Vector store (Qdrant) -------------------------------------------
# Leave QDRANT_URL empty for embedded on-disk mode (uses QDRANT_PATH). Set it
# (e.g. http://localhost:6333) to use a Qdrant server, which lifts the
# single-process lock and enables a user_id payload index.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PATH=./data/qdrant
QDRANT_COLLECTION=rag_documents

# --- Application database (PostgreSQL: users, chat history) ----------
# `docker compose up -d postgres` starts a local server matching this default.
# For a managed/remote database, set the full URI (add ?sslmode=require for TLS).
DATABASE_URL=postgresql://raguser:ragpass@localhost:5434/ragdb

# --- Object storage (MinIO / S3-compatible) --------------------------
# Durable per-user storage, keyed under users/{user_id}/:
#   users/{user_id}/chats/{conversation_id}.json           snapshot of a chat
#   users/{user_id}/chats/{conversation_id}/docs/{file}    uploaded original
# SQLite stays the live chat store; MinIO holds the durable copy and the only
# copy of uploaded originals. Leave false to run without MinIO: chats stay in
# SQLite only and originals are discarded after ingest.
# Start one locally with `docker compose up -d` (console at localhost:9001).
STORAGE_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-storage
# Set true (and use real credentials) for any MinIO that isn't on localhost.
MINIO_SECURE=false
MINIO_REGION=

# --- Web layer (FastAPI backend for the React UI) --------------------
# Secret used to sign login (JWT) tokens. MUST be changed for production:
# generate one with `python -c "import secrets; print(secrets.token_urlsafe(32))"`
JWT_SECRET=dev-insecure-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Origins allowed to call the API (comma-separated). Default = Vite dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Keep true for local dev. Set false in production so the server refuses to
# start while JWT_SECRET is still the insecure default.
DEV_MODE=true
# Reject uploads larger than this many megabytes.
MAX_UPLOAD_MB=25

# --- Chunking --------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval / generation -----------------------------------------
TOP_K=4
# Drop retrieved chunks scoring below this (0.0 = keep all). With reranking on,
# applies to the rerank score.
RETRIEVAL_SCORE_THRESHOLD=0.0
# Prior messages fed to the model for follow-up understanding & continuity.
HISTORY_TURNS=6
MAX_OUTPUT_TOKENS=1024
TEMPERATURE=0.2
LOG_QUERIES=true
